# =============================================
# CREATIVES PRO v5 — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# NUNCA expongas este archivo ni lo subas a git.
# =============================================

# --- SUPABASE (requerido) ---
# Encontrás estas claves en: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (requerido) ---
# ⚠️  IMPORTANTE: NO usar NEXT_PUBLIC_ prefix.
# Esta key es SOLO para el servidor (app/api/claude/route.ts).
# Nunca sale al browser. Encontrás la key en: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- OPENAI (opcional — para imágenes DALL-E) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- HOTMART WEBHOOK (opcional) ---
# Configurá el mismo valor en Hotmart → Ferramentas → Webhooks → Hottok
HOTMART_WEBHOOK_SECRET=tu_token_secreto_32_chars
